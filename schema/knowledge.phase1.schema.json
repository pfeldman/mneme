{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mneme.dev/schema/knowledge/v0",
  "title": "Mneme SUT Knowledge (Phase 1 target -- REFERENCE ONLY)",
  "description": "Knowledge a QA agent holds about achieving a goal against a system under test. Stores invariants (what to look for), never coordinates (how to click). Every assertion carries provenance and confidence.",
  "type": "object",
  "required": [
    "schema_version",
    "goal",
    "goal_id",
    "target",
    "meta"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "0"
    },
    "goal_id": {
      "type": "string",
      "description": "Stable id for the goal, reusable across runs and apps (e.g. 'authenticate-user')."
    },
    "goal": {
      "type": "string",
      "description": "Human intent, expressed as a capability of the system, not a UI action."
    },
    "target": {
      "type": "object",
      "required": [
        "app"
      ],
      "additionalProperties": false,
      "properties": {
        "app": {
          "type": "string"
        },
        "environment": {
          "type": "string",
          "description": "e.g. staging, prod"
        },
        "observed_app_versions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Build/version identifiers under which this knowledge was observed."
        }
      }
    },
    "states": {
      "type": "array",
      "description": "Semantic identity of states (e.g. 'login screen'). Recognized via REDUNDANT independent signals.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "recognition_signals"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "recognition_signals": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/signal"
            }
          }
        }
      }
    },
    "success_signals": {
      "type": "array",
      "description": "Observable assertions that the goal was achieved. Prefer behavioral/network/accessibility over text/url.",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "failure_signals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "paths": {
      "type": "array",
      "description": "Alternative routes to the goal as a GRAPH of intents, never a fixed step sequence.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "intent"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "intent": {
            "type": "string",
            "description": "What this path accomplishes, e.g. 'authenticate via email/password'."
          },
          "from_state": {
            "type": "string"
          },
          "to_state": {
            "type": "string"
          },
          "provenance": {
            "$ref": "#/$defs/provenance"
          },
          "confidence": {
            "$ref": "#/$defs/confidence"
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "trigger"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "trigger": {
            "type": "string",
            "description": "The CONDITION under which the risk appears (not just 'sometimes'). e.g. 'after 3 failed logins'."
          },
          "mitigation": {
            "type": "string"
          },
          "provenance": {
            "$ref": "#/$defs/provenance"
          },
          "confidence": {
            "$ref": "#/$defs/confidence"
          },
          "status": {
            "$ref": "#/$defs/status"
          }
        }
      }
    },
    "uncertainties": {
      "type": "array",
      "description": "Open questions the agent could not resolve. First-class: drives future exploration, prevents false certainty.",
      "items": {
        "type": "object",
        "required": [
          "question"
        ],
        "additionalProperties": false,
        "properties": {
          "question": {
            "type": "string"
          },
          "raised_by": {
            "type": "string"
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "required": [
        "created_at",
        "updated_at"
      ],
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "contributing_agents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "signal": {
      "type": "object",
      "required": [
        "type",
        "value",
        "provenance",
        "confidence",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "behavioral",
            "network",
            "accessibility",
            "text",
            "url",
            "visual"
          ],
          "description": "Ordered most->least durable. Raw CSS selectors / xpath / coordinates are intentionally NOT representable (invariants, not coordinates)."
        },
        "value": {
          "type": "string",
          "description": "The observable thing, described semantically. e.g. 'logout action available', 'POST /session returns 200'."
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "status": {
          "$ref": "#/$defs/status"
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "source_type",
        "source_id",
        "last_verified",
        "observation_count"
      ],
      "additionalProperties": false,
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "human",
            "spec",
            "agent"
          ]
        },
        "source_id": {
          "type": "string"
        },
        "observed_app_version": {
          "type": "string"
        },
        "last_verified": {
          "type": "string",
          "format": "date-time"
        },
        "observation_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "believed",
        "contested",
        "stale",
        "quarantined"
      ]
    }
  },
  "$comment": "NOT used in Phase 0. This is the richer target schema (states, paths-as-graph, risks-with-triggers, uncertainties). Provenance updated to match ADR-0005 (source_type/source_id replace the naive independent_sources counter). Reconcile and activate only after the Phase-0 experiment passes."
}